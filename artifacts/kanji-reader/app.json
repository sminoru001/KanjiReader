{
  "expo": {
    "name": "KanjiReader",
    "slug": "kanji-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seuusuario.kanjireader",
      "infoPlist": {
        "NSCameraUsageDescription": "Este aplicativo precisa acessar a câmera para ler Kanjis em tempo real."
      }
    },
    "android": {
      "package": "com.seuusuario.kanjireader",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Este aplicativo precisa de acesso à câmera para reconhecer Kanjis em tempo real."
        }
      ]
    ]
  }
}
